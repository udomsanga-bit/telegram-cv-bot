# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here

# ── Google Drive ───────────────────────────────────────────────────────────────
# Paste the base64-encoded service account JSON key here (see DEPLOY_GUIDE.md)
GOOGLE_SERVICE_ACCOUNT_JSON=base64_encoded_service_account_json_here

# The ID of your shared Google Drive folder (from the folder URL)
# e.g. https://drive.google.com/drive/folders/1ABC123xyz  →  1ABC123xyz
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here
